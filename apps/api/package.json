{
  "name": "@review-ratings/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "dotenv -e ../../.env -- prisma migrate dev",
    "db:migrate:prod": "dotenv -e ../../.env -- prisma migrate deploy",
    "db:seed": "dotenv -e ../../.env -- tsx prisma/seed.ts",
    "seed:launch": "dotenv -e ../../.env -- tsx prisma/seed-launch.ts",
    "db:studio": "dotenv -e ../../.env -- prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "dotenv -e ../../.env -- prisma migrate reset"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.3",
    "@fastify/rate-limit": "^10.2.2",
    "@prisma/client": "^6.5.0",
    "@review-ratings/shared": "workspace:*",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.40.3",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "firebase-admin": "^13.7.0",
    "ioredis": "^5.4.2",
    "meilisearch": "^0.47.0",
    "pino-pretty": "^13.0.0",
    "resend": "^6.9.4",
    "tesseract.js": "^7.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.13.10",
    "dotenv-cli": "^8.0.0",
    "prisma": "^6.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  }
}
