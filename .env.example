# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_URL=http://localhost:3000

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=reviewuser
POSTGRES_PASSWORD=reviewpass
POSTGRES_DB=reviewdb
POSTGRES_PORT=5432
DATABASE_URL=postgresql://reviewuser:reviewpass@localhost:5432/reviewdb

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ── MeiliSearch ──────────────────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_KEY=dev-master-key
MEILISEARCH_PORT=7700

# ── Cloudflare R2 ────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ── SSL Wireless (OTP) ──────────────────────────────────────
SSL_WIRELESS_API_KEY=
SSL_WIRELESS_SID=

# ── Sentry ───────────────────────────────────────────────────
SENTRY_DSN=
